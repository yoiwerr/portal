# ============================================================
# Portal 环境变量模板
# 复制为 .env 后填入实际值
# ============================================================

# --- LLM Provider (必填至少一个) ---
# 支持: dashscope | deepseek | openai | local | auto
LLM_PROVIDER=auto
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120.0

# DashScope (阿里通义千问)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# DeepSeek
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o

# Local (vLLM / SGLang / Ollama)
# LOCAL_LLM_URL=http://localhost:8000/v1

# --- Agent ---
MAX_TOOL_ROUNDS=10
AGENT_TIMEOUT=180.0

# --- RAG / 搜索 ---
TAVILY_API_KEY=tvly-your-tavily-api-key
SEARCH_API_KEY=

# RAG 检索
RAG_TOP_K=3
SIMILARITY_THRESHOLD=0.6

# Rerank (百炼 qwen3-rerank, 复用 DASHSCOPE_API_KEY)
RERANK_ENABLED=true
RERANK_MODEL=qwen3-rerank
RERANK_TOP_K=5
RERANK_COARSE_K=20

# --- PostgreSQL (ChatLab + MakeItSmooth 共用) ---
PGSQLPASSWORD=your-postgres-password
DB_HOST=localhost
DB_PORT=5432
# MakeItSmooth + ChatLab 共用 chatdemopg 数据库
DB_NAME=chatdemopg

# --- ChatLab (ChatHistoryAnalyst) ---
LANGSMITH_API_KEY=lsv2_your-langsmith-api-key

# --- Memory ---
MEMORY_ENABLED=true

# --- Sandbox (Python 代码执行, 默认关闭) ---
SANDBOX_ENABLED=false
SANDBOX_TIMEOUT=30.0
