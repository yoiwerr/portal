# ============================================================
# Portal 环境变量模板
# 复制为 .env 后填入实际值
# ============================================================

# --- LLM Provider (必填至少一个) ---
LLM_PROVIDER=auto
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120.0

# DashScope (阿里通义千问 — 默认)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# DeepSeek (ChatLab 必须)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI (可选)
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o

# Local vLLM / Ollama (可选)
# LOCAL_LLM_URL=http://localhost:8000/v1

# --- LLM 参数 ---
MAX_TOOL_ROUNDS=10
AGENT_TIMEOUT=180.0

# --- PostgreSQL (ChatLab + MakeItSpecific 共用 pgvector 容器) ---
PGSQLPASSWORD=your-postgres-password
DB_HOST=localhost          # ChatLab 用 DB_HOST / MakeItSpecific 也可用 DB_* 系列
DB_PORT=5432
DB_NAME=chatdemopg
# MakeItSpecific 同样可配 PG_* 系列（优先级: DB_* > PG_* > 默认值）:
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=chatdemopg
# PG_USER=postgres

# --- RAG ---
RAG_TOP_K=3
SIMILARITY_THRESHOLD=0.6
RERANK_ENABLED=true
RERANK_MODEL=qwen3-rerank
RERANK_TOP_K=5
RERANK_COARSE_K=20

# --- Agent ---
MEMORY_ENABLED=true
SANDBOX_ENABLED=false
SANDBOX_TIMEOUT=30.0

# --- ChatLab ---
TAVILY_API_KEY=tvly-your-tavily-api-key
LANGSMITH_API_KEY=lsv2_your-langsmith-api-key
